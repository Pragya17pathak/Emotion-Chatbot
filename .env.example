# 1. Copy this file: cp .env.example .env
# 2. Replace the placeholder with your real Gemini API key
# 3. Add GEMINI_API_KEY to your Vercel project settings under
#    Project → Settings → Environment Variables

GEMINI_API_KEY=google_gemini_api_key
